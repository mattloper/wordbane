# --- Godot ---
# Editor import cache & generated metadata (regenerated on first open/run).
godot_version/.godot/
*.import
export_presets.cfg

# --- Python / uv ---
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# --- Generated art cache (portraits/boons/tombstones; regenerated on demand) ---
.cache/

# --- Cloudflare wrangler (local CLI state) ---
.wrangler/

# --- OS ---
.DS_Store

# NOTE: shared_data/*.json IS committed on purpose — some of it is generated by
# the Python tooling but the game depends on it at runtime. Regenerate with:
#   cd wordlist_generator && uv run wordplay-generate
